# App 
NODE_ENV=development
JWT_SECRET=dev-secret-change-in-production

# AWS / LocalStack 
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=documents-uploads
DYNAMODB_TABLE=documents-documents
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:documents-notifications
ALLOWED_ORIGINS=https://app.example.com,https://documents-xxx.cloudfront.net

# SQS
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/documents-processing
SQS_DLQ_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/documents-dlq
SQS_THUMBNAIL_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/documents-thumbnail-jobs
SQS_POLLING_INTERVAL=5000
SQS_MAX_MESSAGES=5

# Ports
API_PORT=3001
WORKER_PORT=3002
FRONTEND_PORT=3000

# API / Worker 
CORS_ORIGIN=http://localhost

#  AI
AI_PROVIDER=ollama
#smallest model: smollm2:135m
AI_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
# Uncomment to use cloud providers instead of Ollama:
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-3-haiku-20240307
# AI_PROVIDER=bedrock
# AI_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# LocalStack
LOCALSTACK_SERVICES=s3,sqs,dynamodb,sns,logs,cloudwatch
LOCALSTACK_DEBUG=0

# Ollama
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Auth service
# Set to "cognito" to use AWS Cognito instead of Keycloak
AUTH_PROVIDER=keycloak

# Keycloak - used when AUTH_PROVIDER=keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=documents
KEYCLOAK_CLIENT_ID=documents-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_ID=documents-api
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME_IN_ENV
# Master-realm admin creds used ONLY by the Keycloak container itself on first boot
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# JWT validation
AUTH_JWKS_URI=http://localhost:8080/realms/documents/protocol/openid-connect/certs
AUTH_ISSUER=http://localhost:8080/realms/documents
AUTH_AUDIENCE=documents-app

# Cognito - used when AUTH_PROVIDER=cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost
