{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "dist-e2e",
        "types": ["jest", "node"],
        "paths": {
            "@documents/shared": ["../../packages/shared/src"],
            "@config/*": ["./src/config/*"],
            "@common/*": ["./src/common/*"],
            "@modules/*": ["./src/modules/*"]
        }
    },
    "include": ["src/**/*.ts", "test/**/*.ts"]
}
